# Copy to .env and adjust. For local Postgres:
# docker compose up -d (from repo root)
DATABASE_URL="postgresql://movietracker:movietracker@localhost:5432/movietracker"

JWT_ACCESS_SECRET="change-me-to-a-long-random-string-min-32-chars"
JWT_REFRESH_SECRET="change-me-another-long-random-string"

# Optional: comma-separated origins (default allows http://localhost:5173)
CORS_ORIGINS="http://localhost:5173"

# LLM (optional — without keys, AI routes return deterministic mock JSON)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
# Groq (https://console.groq.com) — backend uses groq-sdk; seed defaults active provider to Groq + Llama 4 Scout when DB is created fresh
GROQ_API_KEY=""
TOGETHER_API_KEY=""

# OMDb (optional — powers /api/movies/external/* IMDb-linked search & details)
# https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=""

# TMDB / The Movie Database v3 API (optional — discover & import posters, genres, TMDB votes, credits)
# https://developer.themoviedb.org/docs/getting-started
# Prefer read-access JWT (Bearer) from account Settings → API; otherwise use API key as query param.
TMDB_READ_ACCESS_TOKEN=""
TMDB_API_KEY=""
